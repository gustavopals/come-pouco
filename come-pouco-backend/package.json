{
  "name": "come-pouco-backend",
  "version": "1.0.0",
  "description": "API do projeto Come Pouco",
  "main": "dist/server.js",
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only src/server.ts",
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "prisma migrate deploy && node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "auth:check": "node scripts/auth-hardening-check.js",
    "auth:smoke": "node scripts/auth-smoke-test.js",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.js"
  },
  "keywords": [
    "express",
    "postgres",
    "auth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.923.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.3",
    "@types/node": "^24.5.2",
    "@types/qrcode": "^1.5.6",
    "prisma": "^7.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
